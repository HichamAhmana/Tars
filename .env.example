# ─────────────────────────────────────────────────────────────────────────────
#   TARS v2 — sample environment file. Copy to `.env` and fill in what you need.
#   NOTHING in here is required; every value has a sensible default.
# ─────────────────────────────────────────────────────────────────────────────

# ── Engine ─────────────────────────────────────────────────────────────────
TARS_WAKE_WORD=tars
TARS_DEBUG=0

# Wake-word detection (opt-in — free key at https://console.picovoice.ai)
# TARS_PORCUPINE_ACCESS_KEY=

# Speech-to-text: "google" (online, no key) or "whisper" (local, offline)
TARS_STT_PROVIDER=google
# TARS_WHISPER_MODEL=base.en
# TARS_WHISPER_DEVICE=cpu

# Text-to-speech: "pyttsx3" (offline) or "edge" (Microsoft neural voices)
TARS_TTS_PROVIDER=edge
TARS_TTS_RATE=190
TARS_TTS_VOLUME=1.0
TARS_TTS_EDGE_VOICE=en-US-AriaNeural

# Brain: "rules" (default keyword router) | "openai" | "groq" | "ollama" | "gemini"
TARS_BRAIN_PROVIDER=rules
# TARS_BRAIN_MODEL=gpt-4o-mini
# TARS_BRAIN_API_KEY=
# TARS_BRAIN_BASE_URL=

# ── Backend ────────────────────────────────────────────────────────────────
TARS_DEBUG=1
TARS_REQUIRE_AUTH=0
# TARS_SECRET_KEY=         # REQUIRED for production deployments
# TARS_ALLOWED_HOSTS=localhost,127.0.0.1
# TARS_CORS_ORIGINS=http://localhost:3000

# Shared secret used by both the engine and the dashboard when REQUIRE_AUTH=1
# TARS_API_TOKEN=
# TARS_API_BASE=http://localhost:8000/api
